# Per-user state — generated at run time, never committed
state/cached-ids.json
state/companies.json
state/.setup_complete
state/last_recycle.json
state/few_shot_examples.json
state/re-score-log.json

# Per-user config — written by setup wizard or user edits, never committed.
# Authoritative source-of-truth lives in Notion (cloud mode) or here (local mode).
config/profile.json
config/custom-companies.json

# Claude Code per-project settings (user adds their own)
.claude/settings.local.json

# Outputs (markdown fallback files, run logs, ad-hoc dumps)
outputs/

# Notion token (should NEVER be in repo; defensive)
**/notion-token
**/.notion-token

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local fresh-install test scratch directory (cloned copy of this repo)
/job-search/
.claude/worktrees/
